    <script>
        // Slide navigation
        function showSlide(slideNum) {
            const slides = document.querySelectorAll('.slide');
            const buttons = document.querySelectorAll('.nav-btn');
            
            slides.forEach(slide => slide.classList.remove('active'));
            buttons.forEach(btn => btn.classList.remove('active'));
            
            document.getElementById('slide' + slideNum).classList.add('active');
            buttons[slideNum - 1].classList.add('active');

            // Smooth scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Animate data flow
        function animateFlow() {
            const nodes = document.querySelectorAll('.node');
            const lines = document.querySelectorAll('.connection-line');
            
            nodes.forEach((node, index) => {
                setTimeout(() => {
                    node.style.background = 'rgba(102, 126, 234, 0.6)';
                    node.style.transform = 'scale(1.1)';
                    node.style.boxShadow = '0 0 30px rgba(102, 126, 234, 0.8)';
                    
                    setTimeout(() => {
                        node.style.background = 'rgba(102, 126, 234, 0.2)';
                        node.style.transform = 'scale(1)';
                        node.style.boxShadow = 'none';
                    }, 500);
                }, index * 600);
            });

            lines.forEach((line, index) => {
                setTimeout(() => {
                    line.style.background = 'linear-gradient(90deg, #667eea, #764ba2, #f093fb)';
                    line.style.height = '5px';
                    
                    setTimeout(() => {
                        line.style.background = 'linear-gradient(90deg, #667eea, #764ba2)';
                        line.style.height = '3px';
                    }, 500);
                }, index * 600 + 300);
            });
        }

        // Auto-start animation on load
        window.addEventListener('load', function() {
            setTimeout(animateFlow, 1000);
        });

        // Keyboard navigation
        document.addEventListener('keydown', function(e) {
            const activeSlide = document.querySelector('.slide.active');
            const slideNum = parseInt(activeSlide.id.replace('slide', ''));
            
            if (e.key === 'ArrowRight' && slideNum < 7) {
                showSlide(slideNum + 1);
            } else if (e.key === 'ArrowLeft' && slideNum > 1) {
                showSlide(slideNum - 1);
            }
        });
    </script>
