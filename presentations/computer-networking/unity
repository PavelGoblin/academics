<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chapter 13: Ethernet Networks</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #0f3460;
            --secondary: #16213e;
            --accent: #00d4ff;
            --accent2: #00ff88;
            --text: #e0e0e0;
            --dark-bg: #0a1a2e;
            --card-bg: rgba(15, 52, 96, 0.3);
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @keyframes slideInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInScale {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        @keyframes floatHover {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }

        @keyframes glowPulse {
            0%, 100% {
                box-shadow: 0 0 20px rgba(0, 212, 255, 0.4),
                            0 0 40px rgba(0, 212, 255, 0.2);
            }
            50% {
                box-shadow: 0 0 30px rgba(0, 212, 255, 0.6),
                            0 0 60px rgba(0, 212, 255, 0.3);
            }
        }

        @keyframes shimmer {
            0% { background-position: -1000px 0; }
            100% { background-position: 1000px 0; }
        }

        @keyframes textGlow {
            0%, 100% { text-shadow: 0 0 10px rgba(0, 212, 255, 0.5); }
            50% { text-shadow: 0 0 20px rgba(0, 212, 255, 0.8), 0 0 30px rgba(102, 51, 255, 0.5); }
        }

        @keyframes borderGlow {
            0%, 100% { border-color: rgba(0, 212, 255, 0.5); }
            50% { border-color: rgba(102, 51, 255, 0.8); }
        }

        @keyframes progressFill {
            from { width: 0%; }
            to { width: 100%; }
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(-45deg, var(--primary), var(--secondary), #0a3a52, #1a1a2e);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            color: var(--text);
            min-height: 100vh;
            line-height: 1.7;
            font-size: 18px; /* Increased base font size */
        }

        /* Navigation Bar */
        nav {
            background: linear-gradient(90deg, var(--primary) 0%, var(--secondary) 25%, #0a3a52 75%, #1a1a2e 100%);
            padding: 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 8px 32px rgba(0, 212, 255, 0.3);
            animation: slideInDown 0.8s ease-out;
        }

        nav::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            animation: shimmer 3s infinite;
        }

        .nav-container {
            max-width: 1600px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .nav-brand {
            color: var(--accent);
            font-size: 1.6em; /* Increased font size */
            font-weight: 700;
            padding: 18px 0;
            min-width: 280px;
            animation: textGlow 2s ease-in-out infinite;
            letter-spacing: 1px;
        }

        .nav-links {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
        }

        .nav-link {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(102, 51, 255, 0.1));
            color: var(--text);
            border: 2px solid rgba(0, 212, 255, 0.3);
            padding: 12px 20px; /* Increased padding */
            font-size: 1.05em; /* Increased font size */
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 8px;
            white-space: nowrap;
            font-weight: 600;
            position: relative;
            overflow: hidden;
        }

        .nav-link::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: rgba(0, 212, 255, 0.2);
            transition: left 0.4s;
            z-index: -1;
        }

        .nav-link:hover::before {
            left: 0;
        }

        .nav-link:hover {
            transform: translateY(-3px);
            border-color: var(--accent);
            color: var(--accent);
            box-shadow: 0 8px 16px rgba(0, 212, 255, 0.2);
        }

        .nav-link.active {
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            color: var(--primary);
            border-color: var(--accent2);
            font-weight: 700;
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
            animation: glowPulse 2s ease-in-out infinite;
        }

        /* Main Content */
        .content-wrapper {
            max-width: 1600px;
            margin: 0 auto;
            padding: 50px 30px;
        }

        .section {
            display: none;
            animation: fadeInScale 0.6s ease-out;
        }

        .section.active {
            display: block;
        }

        /* Title Section */
        .title-section {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(102, 51, 255, 0.1));
            border: 2px solid rgba(0, 212, 255, 0.3);
            color: white;
            padding: 100px 50px;
            border-radius: 20px;
            text-align: center;
            margin-bottom: 50px;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

        .title-section::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, rgba(0, 212, 255, 0.1) 0%, transparent 70%);
            animation: floatHover 6s ease-in-out infinite;
            pointer-events: none;
        }

        .title-section h1 {
            font-size: 4em; /* Increased font size */
            margin-bottom: 20px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: textGlow 2s ease-in-out infinite;
            position: relative;
            z-index: 1;
            letter-spacing: 2px;
        }

        .title-section h2 {
            font-size: 2.5em; /* Increased font size */
            margin-bottom: 40px;
            color: #b0e0ff;
            font-weight: 300;
            animation: slideInUp 0.8s ease-out 0.2s both;
        }

        .institute-info {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.15), rgba(102, 51, 255, 0.15));
            padding: 30px;
            border-radius: 12px;
            margin: 40px auto;
            border: 2px solid rgba(0, 212, 255, 0.4);
            border-left: 5px solid var(--accent);
            max-width: 600px;
            animation: slideInUp 0.8s ease-out 0.4s both;
            backdrop-filter: blur(10px);
            position: relative;
            z-index: 1;
        }

        .institute-info p {
            font-size: 1.3em; /* Increased font size */
            margin: 10px 0;
            color: var(--text);
        }

        /* Team Section */
        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
            margin: 40px 0;
        }

        .team-member {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.08), rgba(102, 51, 255, 0.08));
            padding: 30px;
            border-radius: 15px;
            border: 2px solid rgba(0, 212, 255, 0.3);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            border-left: 5px solid var(--accent);
            backdrop-filter: blur(10px);
            animation: fadeInScale 0.6s ease-out;
        }

        .team-member:nth-child(1) { animation-delay: 0s; }
        .team-member:nth-child(2) { animation-delay: 0.1s; }
        .team-member:nth-child(3) { animation-delay: 0.2s; }
        .team-member:nth-child(4) { animation-delay: 0.3s; }
        .team-member:nth-child(5) { animation-delay: 0.4s; }
        .team-member:nth-child(6) { animation-delay: 0.5s; }
        .team-member:nth-child(7) { animation-delay: 0.6s; }

        .team-member:hover {
            transform: translateY(-12px);
            border-color: var(--accent2);
            box-shadow: 0 20px 40px rgba(0, 212, 255, 0.2);
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.15), rgba(102, 51, 255, 0.15));
        }

        .team-member.leader {
            border: 2px solid var(--accent2);
            background: linear-gradient(135deg, rgba(0, 255, 136, 0.15), rgba(0, 212, 255, 0.15));
            animation: glowPulse 2s ease-in-out infinite;
        }

        .leader-badge {
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            color: var(--primary);
            padding: 12px 20px; /* Increased padding */
            border-radius: 25px;
            font-size: 1.1em; /* Increased font size */
            font-weight: 700;
            display: inline-block;
            margin-bottom: 15px;
            letter-spacing: 1px;
            box-shadow: 0 4px 12px rgba(0, 212, 255, 0.3);
        }

        .team-name {
            font-size: 1.5em; /* Increased font size */
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 10px;
        }

        .team-id {
            font-size: 1.2em; /* Increased font size */
            color: #b0e0ff;
        }

        .teacher-info {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.15), rgba(102, 51, 255, 0.15));
            padding: 40px;
            border-radius: 15px;
            border: 2px solid rgba(0, 212, 255, 0.4);
            border-left: 5px solid var(--accent2);
            margin-top: 50px;
            text-align: center;
            animation: fadeInScale 0.8s ease-out;
            backdrop-filter: blur(10px);
        }

        .teacher-info h3 {
            font-size: 1.6em; /* Increased font size */
            color: var(--accent);
            margin-bottom: 15px;
            font-weight: 700;
        }

        .teacher-info p {
            font-size: 1.3em; /* Increased font size */
            color: var(--text);
        }

        /* Content Sections */
        .section-title {
            font-size: 3em; /* Increased font size */
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 50px 0 40px;
            padding-bottom: 20px;
            border-bottom: 3px solid rgba(0, 212, 255, 0.5);
            animation: slideInDown 0.6s ease-out;
            letter-spacing: 1px;
            font-weight: 700;
        }

        .section-content {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.08), rgba(102, 51, 255, 0.08));
            padding: 50px;
            border-radius: 15px;
            border: 2px solid rgba(0, 212, 255, 0.3);
            margin-bottom: 40px;
            backdrop-filter: blur(10px);
            animation: slideInUp 0.6s ease-out 0.2s both;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }

        .content-subsection {
            margin: 40px 0;
            animation: slideInUp 0.6s ease-out;
        }

        .content-subsection h3 {
            font-size: 2em; /* Increased font size */
            color: var(--accent);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 700;
        }

        .content-subsection h4 {
            font-size: 1.6em; /* Increased font size */
            color: var(--accent2);
            margin: 25px 0 15px;
            font-weight: 700;
        }

        .content-subsection p {
            font-size: 1.3em; /* Increased font size */
            line-height: 1.9;
            color: #d0d0d0;
            margin-bottom: 18px;
        }

        .content-subsection ul {
            list-style: none;
            padding: 0;
        }

        .content-subsection li {
            font-size: 1.3em; /* Increased font size */
            line-height: 1.9;
            color: #d0d0d0;
            margin: 15px 0;
            padding-left: 30px;
            position: relative;
        }

        .content-subsection li::before {
            content: "▸";
            position: absolute;
            left: 0;
            color: var(--accent);
            font-weight: bold;
            font-size: 1.5em; /* Increased font size */
            animation: textGlow 2s ease-in-out infinite;
        }

        /* Info Cards */
        .info-card {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.15), rgba(102, 51, 255, 0.1));
            border: 2px solid rgba(0, 212, 255, 0.4);
            border-left: 5px solid var(--accent);
            padding: 30px;
            border-radius: 12px;
            margin: 30px 0;
            transition: all 0.4s;
            backdrop-filter: blur(10px);
        }

        .info-card:hover {
            transform: translateX(8px);
            border-color: var(--accent2);
            box-shadow: 0 10px 30px rgba(0, 212, 255, 0.2);
        }

        .info-card h4 {
            color: var(--accent2);
            font-size: 1.5em; /* Increased font size */
            margin-bottom: 15px;
            font-weight: 700;
        }

        .highlight-box {
            background: linear-gradient(135deg, rgba(255, 165, 0, 0.12), rgba(255, 215, 0, 0.08));
            border: 2px solid rgba(255, 165, 0, 0.4);
            border-left: 5px solid #ffa500;
            padding: 30px;
            border-radius: 12px;
            margin: 30px 0;
            transition: all 0.4s;
            backdrop-filter: blur(10px);
        }

        .highlight-box:hover {
            transform: translateX(8px);
            box-shadow: 0 10px 30px rgba(255, 165, 0, 0.15);
        }

        .highlight-box h4 {
            color: #ffb347;
            font-size: 1.5em; /* Increased font size */
            margin-bottom: 15px;
            font-weight: 700;
        }

        /* Tables */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin: 30px 0;
            border-radius: 10px;
            overflow: hidden;
            font-size: 1.1em; /* Increased font size */
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        }

        .data-table th {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: var(--accent);
            padding: 20px;
            text-align: left;
            font-weight: 700;
            font-size: 1.2em; /* Increased font size */
            border-bottom: 2px solid rgba(0, 212, 255, 0.5);
            letter-spacing: 1px;
        }

        .data-table td {
            padding: 18px 20px;
            border-bottom: 1px solid rgba(0, 212, 255, 0.2);
            color: #d0d0d0;
            font-size: 1.1em; /* Increased font size */
            background: var(--card-bg);
        }

        .data-table tbody tr {
            transition: all 0.3s;
        }

        .data-table tbody tr:hover {
            background: rgba(0, 212, 255, 0.12);
            transform: scale(1.01);
        }

        /* Emphasis */
        .highlight {
            background: linear-gradient(120deg, rgba(0, 212, 255, 0.25), rgba(0, 255, 136, 0.15));
            padding: 4px 10px;
            border-radius: 5px;
            font-weight: 700;
            color: var(--accent);
            border-bottom: 2px solid var(--accent);
            font-size: 1.1em; /* Increased font size */
        }

        strong {
            color: var(--accent2);
            font-weight: 700;
            font-size: 1.05em; /* Increased font size */
        }

        /* Progress Bar */
        .progress-container {
            width: 100%;
            height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            margin: 20px 0;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--accent2));
            border-radius: 4px;
            animation: progressFill 1s ease-out;
        }

        /* Frame Visualization */
        .frame-visualization {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin: 30px 0;
            justify-content: center;
        }

        .frame-field {
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            color: var(--primary);
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            min-width: 120px;
            font-weight: 700;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
            font-size: 1.1em; /* Increased font size */
        }

        .frame-field:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 212, 255, 0.3);
        }

        .frame-field .tooltip {
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.8);
            color: white;
            padding: 10px;
            border-radius: 5px;
            width: 200px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
            z-index: 10;
            font-weight: normal;
            font-size: 1em; /* Increased font size */
        }

        .frame-field:hover .tooltip {
            opacity: 1;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .nav-container {
                flex-direction: column;
                gap: 15px;
                padding: 15px 20px;
            }

            .nav-brand {
                min-width: 100%;
                text-align: center;
            }

            .nav-links {
                width: 100%;
                justify-content: center;
            }

            .section-title {
                font-size: 2.5em;
            }

            .content-subsection h3 {
                font-size: 1.8em;
            }

            .team-grid {
                grid-template-columns: 1fr;
            }

            .section-content {
                padding: 30px;
            }

            .title-section {
                padding: 60px 30px;
            }

            .title-section h1 {
                font-size: 3em;
            }
        }

        @media (max-width: 768px) {
            body {
                font-size: 16px;
            }

            .content-wrapper {
                padding: 25px 15px;
            }

            .section-content {
                padding: 25px;
            }

            .content-subsection p,
            .content-subsection li {
                font-size: 1.2em;
            }

            .nav-link {
                padding: 10px 12px;
                font-size: 1em;
            }

            .title-section {
                padding: 40px 20px;
            }

            .title-section h1 {
                font-size: 2.2em;
            }

            .title-section h2 {
                font-size: 1.5em;
            }

            .section-title {
                font-size: 2em;
            }
        }
    </style>
</head>
